<!DOCTYPE html>
<html lang="en" xmlns:v="urn:schemas-microsoft-com:vml" xmlns:o="urn:schemas-microsoft-com:office:office">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<!--[if gte mso 9]><xml><o:OfficeDocumentSettings><o:AllowPNG/><o:PixelPerInch>96</o:PixelPerInch></o:OfficeDocumentSettings></xml><![endif]-->
<title>Welcome to Cruzy+</title>
</head>
<body style="margin:0;padding:0;background:#f5f7fa;font-family:Poppins,Arial,sans-serif;">
<table width="100%" cellpadding="0" cellspacing="0" bgcolor="#f5f7fa" style="background:#f5f7fa;padding:40px 0;">
  <tr><td align="center">
    <!--[if mso]><table cellpadding="0" cellspacing="0" width="600" align="center"><tr><td><![endif]-->
    <table width="600" cellpadding="0" cellspacing="0" bgcolor="#ffffff" style="background:#fff;border-radius:12px;overflow:hidden;box-shadow:0 4px 24px rgba(0,0,0,0.08);">

      <!-- Header -->
      <tr>
        <td bgcolor="#10559a" style="background:#10559a;background:linear-gradient(135deg,#10559a 0%,#1a2b4a 100%);padding:36px 40px;text-align:center;">
          <!--[if mso]><v:rect xmlns:v="urn:schemas-microsoft-com:vml" fill="true" stroke="false" style="width:600px;height:95px;"><v:fill type="gradient" color="#10559a" color2="#1a2b4a" angle="135"/><v:textbox inset="0,0,0,0" style="mso-fit-shape-to-text:true;"><center><![endif]-->
          <h1 style="margin:0;font-family:Montserrat,Arial,sans-serif;font-size:32px;font-weight:800;color:#fff;letter-spacing:-0.5px;">Cruzy+</h1>
          <p style="margin:4px 0 0;color:#7bb3e8;font-size:13px;letter-spacing:1px;">POWERED BY CARNIVAL</p>
          <!--[if mso]></center></v:textbox></v:rect><![endif]-->
        </td>
      </tr>

      <!-- Body -->
      <tr>
        <td style="padding:48px 40px 32px;">
          <h2 style="margin:0 0 16px;font-family:Montserrat,Arial,sans-serif;font-size:24px;color:#1a2b4a;">Welcome aboard, {{{Recipient.FirstName}}}! 🚢</h2>
          <p style="margin:0 0 16px;color:#555;font-size:15px;line-height:1.6;">
            Your Cruzy+ membership has been created. You now have access to exclusive member pricing, rewards, and your personal cruise dashboard.
          </p>
          <p style="margin:0 0 32px;color:#555;font-size:15px;line-height:1.6;">
            Click the button below to set your password and access your account:
          </p>

          <!-- CTA Button -->
          <table cellpadding="0" cellspacing="0" style="margin:0 auto 32px;">
            <tr>
              <td bgcolor="#10559a" style="background:#10559a;border-radius:8px;text-align:center;">
                <!--[if mso]><v:roundrect xmlns:v="urn:schemas-microsoft-com:vml" xmlns:w="urn:schemas-microsoft-com:office:word" href="{{{set_password_url}}}" style="height:52px;v-text-anchor:middle;width:220px;" arcsize="15%" fillcolor="#10559a" stroke="f"><w:anchorlock/><center style="color:#ffffff;font-family:Poppins,Arial,sans-serif;font-size:16px;font-weight:700;">Set My Password</center></v:roundrect><![endif]-->
                <!--[if !mso]><!-->
                <a href="{{{set_password_url}}}" style="display:inline-block;padding:16px 40px;color:#fff;font-family:Poppins,Arial,sans-serif;font-size:16px;font-weight:700;text-decoration:none;border-radius:8px;">
                  Set My Password
                </a>
                <!--<![endif]-->
              </td>
            </tr>
          </table>

          <p style="margin:0 0 8px;color:#999;font-size:13px;text-align:center;">This link expires in 24 hours.</p>
          <p style="margin:0 0 32px;color:#999;font-size:12px;text-align:center;word-break:break-all;">
            Or copy this link: {{{set_password_url}}}
          </p>

          <hr style="border:none;border-top:1px solid #eee;margin:0 0 24px;"/>

          <p style="margin:0;color:#999;font-size:13px;line-height:1.6;">
            Your Member ID: <strong style="color:#1a2b4a;font-family:monospace;">{{{member_id}}}</strong><br/>
            Questions? Call us at <a href="tel:8554147823" style="color:#10559a;">855-414-7823</a>
          </p>
        </td>
      </tr>

      <!-- Footer -->
      <tr>
        <td bgcolor="#f8fafc" style="background:#f8fafc;padding:24px 40px;border-top:1px solid #eee;text-align:center;">
          <p style="margin:0;color:#aaa;font-size:12px;">© 2026 Cruzy+ · Powered by Carnival · <a href="https://cruzy.com" style="color:#10559a;">cruzy.com</a></p>
        </td>
      </tr>

    </table>
    <!--[if mso]></td></tr></table><![endif]-->
  </td></tr>
</table>
</body>
</html>
